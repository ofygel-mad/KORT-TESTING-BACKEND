# ═══════════════════════════════════════════════════════════════
# KORT — Railway Environment Variables
# Скопируй нужный блок в Railway → Service → Variables
# ═══════════════════════════════════════════════════════════════

# ─── РЕЖИМ 1: Только фронтенд (нет Django) ───────────────────
# Используй пока бэкенд ещё не задеплоен.
# Всё работает через mock-данные прямо в браузере.
#
# Тестовые аккаунты:
#   owner@demo.kz   / demo  — полный доступ владельца
#   admin@demo.kz   / demo  — администратор
#   manager@demo.kz / demo  — менеджер
#   employee@demo.kz/ demo  — сотрудник без компании
#
VITE_MOCK_API=true


# ─── РЕЖИМ 2: Фронт + реальный Django-бэкенд ─────────────────
# Когда Django задеплоен как отдельный Railway-сервис.
#
# VITE_MOCK_API=false
# VITE_API_BASE_URL=https://kort-backend-production.up.railway.app/api/v1


# ─── ОПЦИОНАЛЬНО (оба режима) ────────────────────────────────
# God-mode console через `access "пароль"` в браузерной консоли.
# По умолчанию включён (пароль: 1234). Чтобы отключить:
# VITE_CONSOLE_LOCAL_ACCESS=false

# Sentry DSN для трекинга ошибок:
# VITE_SENTRY_DSN=https://...
