# ═══════════════════════════════════════════════════════════════════════════
# KORT — Production Environment Variables
# Скопируй в .env и заполни перед деплоем
# На Railway — добавить в Variables панели каждого сервиса
# ═══════════════════════════════════════════════════════════════════════════

# ── Backend (Railway: сервис "backend") ──────────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@HOST:5432/kort_db
JWT_ACCESS_SECRET=<минимум-32-рандомных-символа>
JWT_REFRESH_SECRET=<минимум-32-рандомных-символа>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PORT=8000
HOST=0.0.0.0
# CORS_ORIGIN — публичный URL фронтенда (без слеша на конце)
CORS_ORIGIN=https://your-frontend.railway.app
CONSOLE_SERVICE_PASSWORD=<сильный-пароль>
NODE_ENV=production

# ── Frontend (Railway: сервис "frontend") ────────────────────────────────────
# VITE_API_BASE_URL — устанавливается как Build Variable в Railway
# Если фронт и бэк на одном домене через nginx-proxy → оставь /api/v1
# Если отдельные Railway-сервисы → ставь полный URL бэкенда
VITE_API_BASE_URL=https://your-backend.railway.app/api/v1
# BACKEND_URL — URL бэкенда для nginx-proxy (runtime, не build time)
# Важно: без /api/v1 на конце. Пример: https://your-backend.railway.app
# Если не задать, контейнер фронта всё равно поднимется, но proxy /api будет смотреть в localhost.
BACKEND_URL=https://your-backend.railway.app

# ── Docker Compose (локально) ────────────────────────────────────────────────
POSTGRES_USER=kort
POSTGRES_PASSWORD=kort_secret
POSTGRES_DB=kort_db
FRONTEND_PORT=5173
BACKEND_PORT=8000
