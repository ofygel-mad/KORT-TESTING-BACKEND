  @@index([orderId])
  @@index([orderId, createdAt])
  @@map("order_activities")
}

// P3: Schema-driven form templates per organization.
//
// An OrderTemplate describes the fields shown on the New Order form for a
// given org. Two section kinds: 'client' (top-of-form client/order attrs)
// and 'items' (per-line item attrs). Field types match the 9 declared in
// new orders/design_handoff_new_order/FIELD_TYPES.md.
//
// `sections` is intentionally a Json blob — schema-driven forms must let
// admins author arbitrary field combinations without a Prisma migration.
// Server-side validation against the design-handoff schema happens at
// write time in the orders/templates module (P7).
//
// `isSystem = true` marks seeded templates (Blank, Clothing, Watches, etc.)
// that ship with KORT — admins cannot delete them, only clone.
model OrderTemplate {
  id                String   @id @default(cuid())
  orgId             String   @map("org_id")
  name              String
  /// What a line item is called in this template ("позицию", "часы", ...).
  itemNoun          String   @default("позицию") @map("item_noun")
  /// Default unit for the items section ("шт", "т", "кг", ...).
  primaryUnit       String   @default("шт") @map("primary_unit")
  /// Decimal precision for the primary unit (0 for шт, 3 for tonnes).
  primaryPrecision  Int      @default(0) @map("primary_precision")
  /// Full sections+fields shape per design_handoff/SCHEMA_SHAPE.md.
  sections          Json
  isSystem          Boolean  @default(false) @map("is_system")
  /// P0 multi-business: marks the default template the org should preselect
  /// when no explicit `templateId` is supplied (replaces /одежда/i regex).
  isDefault         Boolean  @default(false) @map("is_default")
  /// P0 multi-business: monotonically increments on every `sections` edit so
  /// snapshots on Order can be compared against the live template version.
  version           Int      @default(1)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orders Order[]
  productCatalog WarehouseProductCatalog[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("order_templates")
}

