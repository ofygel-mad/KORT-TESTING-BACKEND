  bin           WarehouseBin?          @relation(fields: [binId], references: [id], onDelete: SetNull)
  parentNode    WarehouseLayoutNode?   @relation("WarehouseLayoutNodeHierarchy", fields: [parentNodeId], references: [id], onDelete: SetNull)
  childNodes    WarehouseLayoutNode[]  @relation("WarehouseLayoutNodeHierarchy")

  @@unique([layoutVersionId, domainType, domainId])
  @@index([orgId, warehouseSiteId, layoutVersionId])
  @@index([zoneId])
  @@index([binId])
  @@index([parentNodeId])
  @@map("warehouse_layout_nodes")
}

