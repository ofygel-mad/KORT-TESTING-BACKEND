model Order {
  id                    String    @id @default(cuid())
  orgId                 String    @map("org_id")
  orderNumber           String    @map("order_number")
  clientId              String    @map("client_id")
  clientName            String    @map("client_name")
  clientPhone           String    @map("client_phone")
  clientPhoneForeign    String?   @map("client_phone_foreign")
  status                String    @default("new")
  paymentStatus         String    @default("not_paid") @map("payment_status")
  priority              String    @default("normal") // legacy: kept for backward compat; use urgency + isDemandingClient
  urgency               String    @default("normal")
  isDemandingClient     Boolean   @default(false) @map("is_demanding_client")
  totalAmount           Float     @default(0) @map("total_amount")
  paidAmount            Float     @default(0) @map("paid_amount")
  dueDate               DateTime? @map("due_date")
  completedAt           DateTime? @map("completed_at")
  cancelledAt           DateTime? @map("cancelled_at")
  // P2: business-level lifecycle stage, derived from `status` + per-item
  // fulfillmentSubstatus. Decouples business stages (draft/committed/
  // fulfilling/completed/cancelled) from the legacy 9-value `status` string.
  lifecycleStage        String?   @map("lifecycle_stage")
  // P2: frozen manager attribution at the moment of completion. Protects
  // future salary calculations from manager edits/reassignments after the
  // order closed. Shape: { managerId, managerName }.
  managerSnapshot       Json?     @map("manager_snapshot")
  cancelReason          String?   @map("cancel_reason")
  streetAddress         String?   @map("street_address")
  city                  String?
  deliveryType          String?   @map("delivery_type")
  source                String?
  expectedPaymentMethod String?   @map("expected_payment_method")
  shippingNote          String?   @map("shipping_note")
  internalNote          String?   @map("internal_note")
  postalCode            String?   @map("postal_code")
  orderDate             DateTime? @map("order_date")
  orderDiscount         Float     @default(0) @map("order_discount")
  deliveryFee           Float     @default(0) @map("delivery_fee")
  bankCommissionPercent Float     @default(0) @map("bank_commission_percent")
  bankCommissionAmount  Float     @default(0) @map("bank_commission_amount")
  paymentBreakdown      Json?     @map("payment_breakdown")
  requiresInvoice       Boolean   @default(true) @map("requires_invoice")
  isArchived            Boolean   @default(false) @map("is_archived")
  archivedAt            DateTime? @map("archived_at")
  deletedAt             DateTime? @map("deleted_at")
  hasReturns            Boolean   @default(false) @map("has_returns")
  managerId             String?   @map("manager_id")
  managerName           String?   @map("manager_name")
  customerType          String    @default("retail") @map("customer_type")
  // P3: schema-driven forms. `templateId` references the OrderTemplate used
  // when this order was created/edited. `extraAttributes` is a free-form bag
  // for client-level custom fields declared by the template's client section.
  // Both are nullable for orders predating the migration; backfill populates
  // them with the org's default Clothing template + empty attributes.
  templateId            String?   @map("template_id")
  extraAttributes       Json?     @map("extra_attributes")
  // P0 multi-business: immutable snapshot of `OrderTemplate.sections` at the
  // moment of creation/update. Read-path uses this (not the live template) so
  // editing a template never breaks historical orders.
  templateSnapshot      Json?     @map("template_snapshot")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  org             Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client          Customer          @relation(fields: [clientId], references: [id])
  template        OrderTemplate?    @relation(fields: [templateId], references: [id])
  items           OrderItem[]
  productionTasks ProductionTask[]
  payments        Payment[]
  transfer        OrderTransfer?
  activities      OrderActivity[]
  invoiceOrders   InvoiceOrder[]
  unpaidAlerts    UnpaidAlert[]
  changeRequests  ChangeRequest[]
  attachments     OrderAttachment[]
  returns         Return[]

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([orgId, paymentStatus])
  @@index([orgId, isArchived])
  @@index([clientId])
  @@map("orders")
}

model OrderItem {
  id                String  @id @default(cuid())
  orderId           String  @map("order_id")
  position          Int     @map("item_position")
  productName       String  @map("product_name")
  quantity          Int     @default(1)
  unitPrice         Float   @map("unit_price")
  fulfillmentMode   String  @default("unassigned") @map("fulfillment_mode")
  // P2: per-item lifecycle stage independent of fulfillmentMode (which is a
  // routing decision). Values: warehouse_pick | in_production | in_transit |
  // delivered | returned. Null = not yet committed.
  fulfillmentSubstatus String? @map("fulfillment_substatus")
  notes             String?
  workshopNotes     String? @map("workshop_notes")
  variantKey        String? @map("variant_key")
  attributesJson    Json?   @map("attributes_json")
  attributesSummary String? @map("attributes_summary")
  // P3: schema-driven forms. Free-form bag for per-item custom fields
  // declared by the active OrderTemplate's items section. Distinct from
  // `attributesJson` (canonical warehouse variant fingerprint) — `attributes`
  // is the *template* payload (whatever the org's fields define), while
  // `attributesJson` stays the strict variant key for inventory lookups.
  attributes        Json?   @map("attributes")

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productionTask ProductionTask?

  @@unique([orderId, position])
  @@index([orderId, position])
  @@map("order_items")
}

