model Conversation {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org          Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([orgId])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  unreadCount    Int       @default(0) @map("unread_count")
  lastReadAt     DateTime? @map("last_read_at")
  joinedAt       DateTime  @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  ORDER_REF
}

model Message {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  senderId       String      @map("sender_id")
  body           String      @db.Text
  type           MessageType @default(TEXT)
  replyToId      String?     @map("reply_to_id")
  editedAt       DateTime?   @map("edited_at")
  deletedAt      DateTime?   @map("deleted_at")
  orderId        String?     @map("order_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  readAt         DateTime?   @map("read_at")

  conversation Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation(fields: [senderId], references: [id])
  replyTo      Message?         @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]        @relation("MessageReplies")
  attachments  ChatAttachment[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model ChatAttachment {
  id          String   @id @default(cuid())
  messageId   String   @map("message_id")
  orgId       String   @map("org_id")
  fileName    String   @map("file_name")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  storagePath String   @map("storage_path")
  width       Int?
  height      Int?
  createdAt   DateTime @default(now()) @map("created_at")

  message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("chat_attachments")
}

model ManualInvoice {
  id            String    @id @default(cuid())
  orgId         String    @map("org_id")
  type          String
  invoiceNum    String    @map("invoice_num")
  title         String
  notes         String?
  createdById   String    @map("created_by_id")
  createdByName String    @map("created_by_name")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  archivedAt    DateTime? @map("archived_at")

  org   Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  items ManualInvoiceItem[]

  @@unique([orgId, invoiceNum])
  @@index([orgId, type])
  @@index([orgId, createdAt])
  @@index([orgId, archivedAt])
  @@map("manual_invoices")
}

model ManualInvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String   @map("invoice_id")
  productName String   @map("product_name")
  quantity    Int      @default(1)
  unitPrice   Float    @map("unit_price")
  /// P0 multi-business: free-form per-item attributes from the active OrderTemplate.
  attributesJson Json?  @map("attributes_json")
  createdAt   DateTime @default(now()) @map("created_at")

  invoice ManualInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("manual_invoice_items")
}
