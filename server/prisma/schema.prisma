generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  AUTH & IDENTITY
// ═══════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  email     String?  @unique // nullable — phone-only employees may have no email
  phone     String?  @unique // unique: used as login identifier for employees
  fullName  String   @map("full_name")
  avatarUrl String?  @map("avatar_url")
  password  String
  status    String   @default("active") // active | pending | inactive
  lastLoginAt DateTime? @map("last_login_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshTokens       RefreshToken[]
  memberships         Membership[]
  passwordResetTokens PasswordResetToken[]
  conversations       ConversationParticipant[]
  sentMessages        Message[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Append-only telemetry/audit stream (R4 — Control Plane).
// No FK relations: audit must survive deletion of the referenced user/org.
// shippedAt = outbox marker — null until the row is pushed to the Control Plane.
model AuditEvent {
  id         String    @id @default(cuid())
  type       String // login | login_failed | request | business | security
  action     String
  orgId      String?   @map("org_id")
  userId     String?   @map("user_id")
  ip         String?
  userAgent  String?   @map("user_agent")
  metadata   Json?
  shippedAt  DateTime? @map("shipped_at")
  occurredAt DateTime  @default(now()) @map("occurred_at")

  @@index([orgId, occurredAt])
  @@index([userId, occurredAt])
  @@index([type, occurredAt])
  @@index([shippedAt])
  @@map("audit_events")
}

model AccountingEntry {
  id           String    @id @default(cuid())
  orgId        String    @map("org_id")
  seq          Int
  type         String
  amount       Float
  currency     String    @default("KZT")
  category     String
  account      String
  counterparty String?
  sourceModule String?   @map("source_module")
  sourceId     String?   @map("source_id")
  sourceLabel  String?   @map("source_label")
  period       String
  author       String
  prevHash     String?   @map("prev_hash")
  hash         String    @unique
  isReconciled Boolean   @default(false) @map("is_reconciled")
  reconciledAt DateTime? @map("reconciled_at")
  reconciledBy String?   @map("reconciled_by")
  tags         String[]  @default([])
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, seq])
  @@index([orgId, period])
  @@index([orgId, type])
  @@index([orgId, sourceModule, sourceId])
  @@map("accounting_entries")
}

model AccountingGap {
  id           String    @id @default(cuid())
  orgId        String    @map("org_id")
  type         String
  severity     String    @default("warning")
  description  String
  sourceModule String    @map("source_module")
  sourceId     String    @map("source_id")
  status       String    @default("open")
  resolvedAt   DateTime? @map("resolved_at")
  resolvedBy   String?   @map("resolved_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, sourceModule, sourceId, type])
  @@index([orgId, status])
  @@map("accounting_gaps")
}

model ImportTemplate {
  id             String    @id @default(cuid())
  orgId          String    @map("org_id")
  name           String
  target         String
  mapping        Json
  headerRowIndex Int       @default(0) @map("header_row_index")
  dataStartRow   Int       @default(1) @map("data_start_row")
  sheetName      String?   @map("sheet_name")
  usedCount      Int       @default(0) @map("used_count")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
  @@map("import_templates")
}

// ═══════════════════════════════════════════════════════════════
//  ORGANIZATIONS & MEMBERSHIPS
// ═══════════════════════════════════════════════════════════════

model Organization {
  id                  String  @id @default(cuid())
  name                String
  slug                String  @unique
  mode                String  @default("basic") // basic | advanced | industrial
  currency            String  @default("KZT")
  industry            String?
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")

  // Extended org profile (Settings → Организация)
  legalName                   String? @map("legal_name")
  bin                         String?
  iin                         String?
  legalForm                   String? @map("legal_form")
  director                    String?
  accountant                  String?
  address                     String?
  city                        String?
  phone                       String?
  email                       String?
  website                     String?
  bankName                    String? @map("bank_name")
  bankBik                     String? @map("bank_bik")
  bankAccount                 String? @map("bank_account")
  shipmentResponsibleName     String? @map("shipment_responsible_name")
  shipmentResponsiblePosition String? @map("shipment_responsible_position")
  transportOrganization       String? @map("transport_organization")
  attorneyNumber              String? @map("attorney_number")
  attorneyDate                String? @map("attorney_date")
  attorneyIssuedBy            String? @map("attorney_issued_by")

  // Operations: document numbering counters + delivery/commission defaults
  orderCounter          Int   @default(0) @map("order_counter")
  invoiceCounter        Int   @default(0) @map("invoice_counter")
  requestCounter        Int   @default(0) @map("request_counter")
  kazpostDeliveryFee    Int   @default(2000) @map("kazpost_delivery_fee")
  railDeliveryFee       Int   @default(3000) @map("rail_delivery_fee")
  airDeliveryFee        Int   @default(5000) @map("air_delivery_fee")
  bankCommissionPercent Float @default(0) @map("bank_commission_percent")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships        Membership[]
  invites            Invite[]
  membershipRequests MembershipRequest[]
  roles              Role[]
  subscription       Subscription?

  // Composability (ЧАСТЬ X — конфигурируемые поверхности)
  tenantConfig          TenantConfig?
  tenantConfigRevisions TenantConfigRevision[]
  tenantConfigPreview   TenantConfigPreview?
  // P3: schema-driven order forms (separate concern from TenantConfig).
  orderTemplates        OrderTemplate[]

  // CRM
  customers Customer[]
  leads     Lead[]
  deals     Deal[]
  tasks     Task[]

  // Operations: orders, production, fulfillment
  orders           Order[]
  materialRequests MaterialRequest[]
  workers          Worker[]
  productSizes     ProductSize[]
  paymentMethods   PaymentMethod[]
  invoices         Invoice[]
  returns          Return[]
  manualInvoices   ManualInvoice[]

  // Warehouse
  warehouseItems                  WarehouseItem[]
  warehouseCategories             WarehouseCategory[]
  warehouseMovements              WarehouseMovement[]
  warehouseReservations           WarehouseReservation[]
  warehouseTransitZones           WarehouseTransitZone[]
  warehouseTransitEntries         WarehouseTransitEntry[]
  warehouseBomLines               WarehouseBOMLine[]
  warehouseAlerts                 WarehouseAlert[]
  warehouseLots                   WarehouseLot[]
  warehouseLocations              WarehouseLocation[]
  warehouseProductCatalog         WarehouseProductCatalog[]
  warehouseSites                  WarehouseSite[]
  warehouseZones                  WarehouseZone[]
  warehouseAisles                 WarehouseAisle[]
  warehouseRacks                  WarehouseRack[]
  warehouseBins                   WarehouseBin[]
  warehouseVariants               WarehouseVariant[]
  warehouseStockLedgerEvents      WarehouseStockLedgerEvent[]
  warehouseStockBalances          WarehouseStockBalance[]
  warehouseStockReservations      WarehouseStockReservation[]
  warehouseTasks                  WarehouseTask[]
  warehouseExceptions             WarehouseException[]
  warehouseAssigneePools          WarehouseAssigneePool[]
  warehouseTaskEvents             WarehouseTaskEvent[]
  warehouseExceptionEvents        WarehouseExceptionEvent[]
  warehouseLayoutVersions         WarehouseLayoutVersion[]
  warehouseLayoutNodes            WarehouseLayoutNode[]
  warehouseOperationDocuments     WarehouseOperationDocument[]
  warehouseSiteReadModels         WarehouseSiteReadModel[]
  warehouseOrderReadModels        WarehouseOrderReadModel[]
  warehouseOutboxRecords          WarehouseOutbox[]
  warehouseProjectionInboxRecords WarehouseProjectionInbox[]
  warehouseLayoutPublishAudits    WarehouseLayoutPublishAudit[]
  accountingEntries               AccountingEntry[]
  accountingGaps                  AccountingGap[]
  importTemplates                 ImportTemplate[]
  adCampaigns                     AdCampaign[]
  adDailyMetrics                  AdDailyMetric[]
  conversations                   Conversation[]
  chatAttachments                 ChatAttachment[]
  kaspiConnections                KaspiConnection[]
  kaspiOrderLinks                 KaspiOrderLink[]

  @@map("organizations")
}

// ═══════════════════════════════════════════════════════════════
//  PLATFORM: PLANS & SUBSCRIPTIONS  (R3 — план как данные)
// ═══════════════════════════════════════════════════════════════

// A plan is data, not a hardcoded string. Seeded; editable by the platform.
model PlanDefinition {
  code        String   @id // basic | advanced | industrial
  name        String
  description String?
  rank        Int      @default(0) // tier ordering for planIncludes()
  maxUsers    Int?     @map("max_users") // null = unlimited
  features    String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("plan_definitions")
}

// One subscription per org. Organization.mode is a denormalized cache of planCode.
model Subscription {
  id          String    @id @default(cuid())
  orgId       String    @unique @map("org_id")
  planCode    String    @map("plan_code")
  status      String    @default("active") // active | trial | suspended | cancelled
  periodStart DateTime  @default(now()) @map("period_start")
  periodEnd   DateTime? @map("period_end")
  trialEndsAt DateTime? @map("trial_ends_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // planCode references PlanDefinition.code; validated in the service layer
  // (kept FK-free for the same reason Organization.mode is an open string).
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ═══════════════════════════════════════════════════════════════
//  COMPOSABILITY: TENANT CONFIG  (ЧАСТЬ X — конфигурируемые поверхности)
// ═══════════════════════════════════════════════════════════════

// The single ACTIVE configurable-surfaces config per org. KORT reads it at
// bootstrap and applies it autonomously. See server/COMPOSABILITY_CONTRACT.md.
model TenantConfig {
  id              String   @id @default(cuid())
  orgId           String   @unique @map("org_id")
  schemaVersion   Int      @default(1) @map("schema_version")
  revision        Int      @default(1)
  config          Json
  manifestVersion String   @map("manifest_version")
  source          String   @default("default") // default | platform | rollback
  appliedAt       DateTime @default(now()) @map("applied_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

// Append-only journal of applied configs — lets KORT self-rollback without CP.
model TenantConfigRevision {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  revision        Int
  schemaVersion   Int      @map("schema_version")
  config          Json
  manifestVersion String   @map("manifest_version")
  source          String // default | platform | rollback
  note            String?
  actor           String? // CP operator id from the service token, or "system"
  appliedAt       DateTime @default(now()) @map("applied_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, revision])
  @@index([orgId, appliedAt])
  @@map("tenant_config_revisions")
}

// Staged preview config — visible only to a preview-flagged operator session.
model TenantConfigPreview {
  id              String   @id @default(cuid())
  orgId           String   @unique @map("org_id")
  config          Json
  manifestVersion String   @map("manifest_version")
  stagedBy        String   @map("staged_by")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("tenant_config_previews")
}

model KaspiConnection {
  id            String    @id @default(cuid())
  orgId         String    @map("org_id")
  sellerName    String?   @map("seller_name")
  apiToken      String    @map("api_token")
  tokenLast4    String    @map("token_last4")
  isActive      Boolean   @default(true) @map("is_active")
  archivedAt    DateTime? @map("archived_at")
  lastCheckedAt DateTime? @map("last_checked_at")
  lastSyncAt    DateTime? @map("last_sync_at")
  lastSyncError String?   @map("last_sync_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  org        Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orderLinks KaspiOrderLink[]

  @@index([orgId, isActive])
  @@index([orgId, archivedAt])
  @@map("kaspi_connections")
}

model KaspiOrderLink {
  id                   String    @id @default(cuid())
  orgId                String    @map("org_id")
  connectionId         String    @map("connection_id")
  externalOrderId      String    @map("external_order_id")
  externalOrderCode    String?   @map("external_order_code")
  externalState        String?   @map("external_state")
  externalStatus       String?   @map("external_status")
  externalDeliveryMode String?   @map("external_delivery_mode")
  internalOrderId      String?   @map("internal_order_id")
  internalOrderType    String?   @map("internal_order_type")
  rawPayload           Json?     @map("raw_payload")
  lastExternalUpdateAt DateTime? @map("last_external_update_at")
  acceptedAt           DateTime? @map("accepted_at")
  completedAt          DateTime? @map("completed_at")
  cancelledAt          DateTime? @map("cancelled_at")
  lastSyncedAt         DateTime? @map("last_synced_at")
  syncError            String?   @map("sync_error")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  org        Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  connection KaspiConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalOrderId])
  @@index([orgId, externalStatus])
  @@index([orgId, externalState])
  @@index([orgId, connectionId])
  @@index([orgId, internalOrderId])
  @@index([connectionId, lastSyncedAt])
  @@map("kaspi_order_links")
}

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String
  quote     String
  rate      Float
  source    String   @default("NBK")
  rateDate  DateTime @map("rate_date")
  fetchedAt DateTime @default(now()) @map("fetched_at")

  @@unique([base, quote, rateDate, source])
  @@index([base, quote, rateDate])
  @@map("exchange_rates")
}

model AdCampaign {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  name        String
  channel     String   @default("target")
  status      String   @default("active")
  managerName String?  @map("manager_name")
  creativeUrl String?  @map("creative_url")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org     Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  metrics AdDailyMetric[]

  @@index([orgId, channel, status])
  @@index([orgId, name])
  @@map("ad_campaigns")
}

model AdDailyMetric {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  campaignId   String   @map("campaign_id")
  date         DateTime
  spendUsd     Float    @default(0) @map("spend_usd")
  exchangeRate Float    @default(0) @map("exchange_rate")
  spendKzt     Float    @default(0) @map("spend_kzt")
  impressions  Int      @default(0)
  reach        Int      @default(0)
  clicks       Int      @default(0)
  leads        Int      @default(0)
  sales        Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign AdCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([orgId, date])
  @@index([orgId, campaignId])
  @@map("ad_daily_metrics")
}

model Membership {
  id     String @id @default(cuid())
  userId String @map("user_id")
  orgId  String @map("org_id")

  // Org membership lifecycle
  status   String    @default("pending") // pending | active | rejected
  source   String    @default("manual") // company_registration | admin_added | invite | request | manual
  joinedAt DateTime? @map("joined_at")

  // Org owner — the member who created the company. Bypasses all permission checks.
  isOwner Boolean @default(false) @map("is_owner")

  // RBAC: role gives a base permission set; per-member overrides refine it.
  roleId String? @map("role_id")

  // Employee-specific fields (populated when source = 'admin_added')
  department            String  @default("")
  addedById             String? @map("added_by_id") // userId of admin who created this employee
  addedByName           String? @map("added_by_name")
  employeeAccountStatus String  @default("active") @map("employee_account_status")
  // ^ values: active | pending_first_login | dismissed
  // 'dismissed' = fired, login blocked; 'pending_first_login' = phone+phone auth required

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  org                 Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role                Role?                      @relation(fields: [roleId], references: [id], onDelete: SetNull)
  permissionOverrides MemberPermissionOverride[]

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([roleId])
  @@map("memberships")
}

// RBAC role — a named bundle of scope.action permissions.
// orgId = null → system role (shared, seeded, isSystem = true).
// orgId set    → custom role created by that company.
model Role {
  id          String   @id @default(cuid())
  orgId       String?  @map("org_id")
  key         String // owner | admin | sales_manager | warehouse_manager | ...
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  permissions String[] @default([]) // scope.action permission keys
  dataScope   String   @default("all") @map("data_scope") // all | own — область данных роли
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org     Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members Membership[]

  @@unique([orgId, key])
  @@index([orgId])
  @@map("roles")
}

// Per-member refinement on top of the role's permission set.
model MemberPermissionOverride {
  id           String @id @default(cuid())
  membershipId String @map("membership_id")
  permission   String // scope.action permission key
  effect       String // 'allow' | 'deny'

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, permission])
  @@index([membershipId])
  @@map("member_permission_overrides")
}

model Invite {
  id          String    @id @default(cuid())
  token       String    @unique
  orgId       String    @map("org_id")
  role        String    @default("manager")
  autoApprove Boolean   @default(true) @map("auto_approve")
  kind        String    @default("referral") // invite | referral
  createdBy   String    @map("created_by")
  expiresAt   DateTime? @map("expires_at")
  usedAt      DateTime? @map("used_at")
  usedBy      String?   @map("used_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("invites")
}

model MembershipRequest {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  orgId         String   @map("org_id")
  fullName      String   @map("full_name")
  email         String
  requestedRole String   @default("viewer") @map("requested_role")
  status        String   @default("pending") // pending | approved | rejected
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@map("membership_requests")
}

// ═══════════════════════════════════════════════════════════════
//  CRM: CUSTOMERS
// ═══════════════════════════════════════════════════════════════

model Customer {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  fullName     String   @map("full_name")
  phone        String?
  email        String?
  companyName  String?  @map("company_name")
  status       String   @default("new")
  source       String?  @default("manual")
  customerType String   @default("retail") @map("customer_type") // retail | wholesale
  notes        String?
  tags         String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leads  Lead[]
  deals  Deal[]
  orders Order[]

  @@index([orgId])
  @@index([orgId, phone])
  @@map("customers")
}

// ═══════════════════════════════════════════════════════════════
//  CRM: LEADS
// ═══════════════════════════════════════════════════════════════

model Lead {
  id            String    @id @default(cuid())
  orgId         String    @map("org_id")
  customerId    String?   @map("customer_id")
  fullName      String    @map("full_name")
  phone         String
  email         String?
  companyName   String?   @map("company_name")
  source        String
  stage         String    @default("new")
  pipeline      String    @default("qualifier")
  assignedTo    String?   @map("assigned_to")
  assignedName  String?   @map("assigned_name")
  callbackAt    DateTime? @map("callback_at")
  meetingAt     DateTime? @map("meeting_at")
  budget        Float?
  comment       String?
  checklistDone String[]  @default([]) @map("checklist_done")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  org      Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  history  LeadHistory[]

  @@index([orgId, pipeline, stage])
  @@map("leads")
}

model LeadHistory {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  type      String
  content   String
  author    String
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_history")
}

// ═══════════════════════════════════════════════════════════════
//  CRM: DEALS
// ═══════════════════════════════════════════════════════════════

model Deal {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  customerId      String?   @map("customer_id")
