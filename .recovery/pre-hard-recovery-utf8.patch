+/**
+ * Generates a reset token and sends a password-reset email.
+ * Always responds with success even if the email isn't found to avoid
+ * leaking whether an account exists.
+ */
+export async function requestPasswordReset(email: string) {
+  const normalized = normalizeEmail(email);
+  const user = await prisma.user.findUnique({ where: { email: normalized } });
+
+  // Respond generically regardless of whether we found the user
+  if (!user || !user.email) {
+    return { ok: true };
+  }
+
+  // Invalidate any existing unused reset tokens for this user
+  await prisma.passwordResetToken.deleteMany({
+    where: { userId: user.id, usedAt: null },
+  });
+
+  const token = nanoid(48);
+  const expiresAt = new Date(Date.now() + 60 * 60 * 1000); // 1 hour
+
+  await prisma.passwordResetToken.create({
+    data: { userId: user.id, token, expiresAt },
+  });
+
+  await sendPasswordResetEmail(user.email, token);
+
+  return { ok: true };
+}
+
+// confirmPasswordReset
+
+/**
+ * Verifies the reset token and sets a new password.
+ * Does NOT require the user to be logged in.
+ */
+export async function confirmPasswordReset(token: string, newPassword: string) {
+  const record = await prisma.passwordResetToken.findUnique({
+    where: { token },
+    include: { user: true },
+  });
+
+  if (!record) {
+    throw new ValidationError('\u0421\u0441\u044b\u043b\u043a\u0430 \u0434\u043b\u044f \u0441\u0431\u0440\u043e\u0441\u0430 \u043f\u0430\u0440\u043e\u043b\u044f \u043d\u0435\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043b\u044c\u043d\u0430 \u0438\u043b\u0438 \u0443\u0436\u0435 \u0431\u044b\u043b\u0430 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0430.');
+  }
+  if (record.usedAt) {
+    throw new ValidationError('\u042d\u0442\u0430 \u0441\u0441\u044b\u043b\u043a\u0430 \u0443\u0436\u0435 \u0431\u044b\u043b\u0430 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0430. \u0417\u0430\u043f\u0440\u043e\u0441\u0438\u0442\u0435 \u043d\u043e\u0432\u0443\u044e.');
+  }
+  if (record.expiresAt < new Date()) {
+    throw new ValidationError('\u0421\u0440\u043e\u043a \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f \u0441\u0441\u044b\u043b\u043a\u0438 \u0438\u0441\u0442\u0451\u043a. \u0417\u0430\u043f\u0440\u043e\u0441\u0438\u0442\u0435 \u043d\u043e\u0432\u0443\u044e.');
+  }
+
+  const hashedPassword = await hashPassword(newPassword);
+
+  await prisma.$transaction(async (tx) => {
+    await tx.user.update({
+      where: { id: record.userId },
+      data: { password: hashedPassword, status: 'active' },
+    });
+
+    await tx.passwordResetToken.update({
+      where: { id: record.id },
+      data: { usedAt: new Date() },
+    });
+
+    // Revoke all existing sessions - user must log in fresh
+    await tx.refreshToken.deleteMany({ where: { userId: record.userId } });
+  });
+
+  return { ok: true };
+}
+
+export async function changeCredentials(
+  userId: string,
+  data: { email: string; new_password: string },
+) {
+  const email = normalizeEmail(data.email);
+  const user = await prisma.user.findUnique({ where: { id: userId } });
+  if (!user) throw new NotFoundError('User', userId);
+
+  const existing = await prisma.user.findUnique({ where: { email } });
+  if (existing && existing.id !== userId) {
+    throw new ConflictError(DUPLICATE_EMAIL_MESSAGE);
+  }
+
+  const hashedPassword = await hashPassword(data.new_password);
+
+  await prisma.$transaction(async (tx) => {
+    await tx.user.update({
+      where: { id: userId },
+      data: {
+        email,
+        password: hashedPassword,
+        status: 'active',
+      },
+    });
+
+    await tx.refreshToken.deleteMany({ where: { userId } });
+  });
+
+  return {
+    ok: true as const,
+    user_id: userId,
+    email,
+  };
+}
