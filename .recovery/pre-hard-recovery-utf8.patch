+type ChapanSection = 'orders' | 'production' | 'ready' | 'archive' | 'invoices' | 'settings';
+
+function resolveFirstChapanRoute() {
+  const permissions = useChapanPermissions();
+
+  if (permissions.canAccessOrders) return '/workzone/chapan/orders';
+  if (permissions.canAccessProduction) return '/workzone/chapan/production';
+  if (permissions.canAccessReady) return '/workzone/chapan/ready';
+  if (permissions.canAccessArchive) return '/workzone/chapan/archive';
+  if (permissions.canAccessInvoices) return '/workzone/chapan/invoices';
+  if (permissions.canManageSettings) return '/workzone/chapan/settings';
+  return '/';
+}
+
+function RequireChapanSection({
+  section,
+  children,
+}: {
+  section: ChapanSection;
+  children: ReactNode;
+}) {
+  const permissions = useChapanPermissions();
+  const fallbackPath = resolveFirstChapanRoute();
+
+  const allowed =
+    (section === 'orders' && permissions.canAccessOrders)
+    || (section === 'production' && permissions.canAccessProduction)
+    || (section === 'ready' && permissions.canAccessReady)
+    || (section === 'archive' && permissions.canAccessArchive)
+    || (section === 'invoices' && permissions.canAccessInvoices)
+    || (section === 'settings' && permissions.canManageSettings);
+
+  if (!allowed) return <Navigate to={fallbackPath} replace />;
+  return <>{children}</>;
+}
